// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// Enums
enum Role {
  CONSUMER
  COLLECTOR
  RECYCLER
  PRODUCER
}

enum PlasticType {
  PET
  HDPE
  PVC
  LDPE
  PP
  PS
  OTHER
}

// Models
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Role-specific metrics
  points    Int      @default(0) // Consumer milestone points
  hederaAccountId String? // For users interacting with Tokens/HCS

  // Relationships
  plasticLogs      PlasticLog[]      @relation("ConsumerLogs")
  collectedBatches CollectionBatch[] @relation("CollectorBatches")
  recyclerBatches  CollectionBatch[] @relation("RecyclerBatches")
  creditsOwned     Credit[]          @relation("CreditOwner")
}

model PlasticLog {
  id          String      @id @default(uuid())
  consumerId  String
  consumer    User        @relation("ConsumerLogs", fields: [consumerId], references: [id])
  weight      Float       // in kg
  type        PlasticType
  timestamp   DateTime    @default(now())
  location    String?     // IoT bin location
  
  // Status tracking
  isCollected Boolean     @default(false)
  batchId     String?
  batch       CollectionBatch? @relation(fields: [batchId], references: [id])

  hcsTopicId  String?     // Traceability topic ID initially created
}

model CollectionBatch {
  id          String       @id @default(uuid())
  collectorId String
  collector   User         @relation("CollectorBatches", fields: [collectorId], references: [id])
  recyclerId  String?
  recycler    User?        @relation("RecyclerBatches", fields: [recyclerId], references: [id])
  
  status      String       @default("IN_TRANSIT") // IN_TRANSIT, DELIVERED, VERIFIED
  totalWeight Float        @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  plastics    PlasticLog[]
  verification Verification?

  hcsMessageId String?     // Track state change on Hedera
}

model Verification {
  id          String          @id @default(uuid())
  batchId     String          @unique
  batch       CollectionBatch @relation(fields: [batchId], references: [id])
  verifiedWeight Float
  quality     String          // e.g., "HIGH", "MIXED"
  timestamp   DateTime        @default(now())
  
  creditMinted Boolean        @default(false)
  
  hcsMessageId String?
}

model Credit {
  id           String   @id @default(uuid())
  tokenId      String   // HTS Token ID
  serialNumber Int?     // If NFT
  amount       Float    // Equivalent weight representing the credit
  ownerId      String
  owner        User     @relation("CreditOwner", fields: [ownerId], references: [id])
  status       String   @default("ACTIVE") // ACTIVE, RETIRED (Burned by producer)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
